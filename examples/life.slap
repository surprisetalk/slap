-- Conway's Game of Life
-- Run with: ./slap-sdl < examples/life.slap

160 'W let
120 'H let
W H mul 'N let
4 'S let

-- State packed into grid list: indices 0..N-1 = cells, N = drawing, N+1 = mx, N+2 = my
N 'I-DRAW let
N 1 plus 'I-MX let
N 2 plus 'I-MY let

-- Look up cell at must wrapped (x, y) via nth must (no grid copy)
'cell (
  H plus H mod W mul
  swap W plus W mod
  plus nth must
) def

-- Count live neighbors of (x, y); gs is a symbol for nth must
'neighbors (
  'cy let 'cx let 'gs let
  gs cx 1 sub cy 1 sub cell
  gs cx       cy 1 sub cell plus
  gs cx 1 plus cy 1 sub cell plus
  gs cx 1 sub cy       cell plus
  gs cx 1 plus cy       cell plus
  gs cx 1 sub cy 1 plus cell plus
  gs cx       cy 1 plus cell plus
  gs cx 1 plus cy 1 plus cell plus
) def

-- Compute next generation
'step (
  'g let
  'g I-DRAW nth must 'dv let
  'g I-MX nth must 'mxv let
  'g I-MY nth must 'myv let
  list 0
  (dup N lt)
  (
    dup W divmod 'y let 'x let
    'g x y neighbors 'n let
    'g over nth must 1 eq
      (n 2 eq n 3 eq or)
      (n 3 eq)
    if
    (1) (0) if
    swap (push) dip 1 plus
  )
  while
  drop
  dv push mxv push myv push
) def

-- Draw SxS block for one alive cell
'draw-cell (
  S mul 'py let
  S mul 'px let
  px py S S 3 fill-rect
) def

-- Draw SxS block in a given color
'draw-cell-color (
  'cc let
  S mul 'py let
  S mul 'px let
  px py S S cc fill-rect
) def

-- Random initial grid + state slots
list N (2 random push) repeat
0 push -1 push -1 push

-- Mouse handlers
'mousedown (
  S div 'mdy let S div 'mdx let
  I-DRAW 1 set must I-MX mdx set must I-MY mdy set must
  mdy W mul mdx plus 1 set must
) on

'mouseup (
  drop drop
  I-DRAW 0 set must
) on

'mousemove (
  S div 'mmy let S div 'mmx let
  I-MX mmx set must I-MY mmy set must
  dup I-DRAW get must 1 eq (
    mmy W mul mmx plus 1 set must
  ) () if
) on

-- Step on each tick (skip when drawing)
'tick (
  drop
  dup I-DRAW get must 0 eq (step) () if
) on

-- Render
(
  'sg let
  0 clear
  'sg I-DRAW nth must 'sdv let
  'sg I-MX nth must 'smxv let
  'sg I-MY nth must 'smyv let
  0 (dup N lt) (
    dup 'ri let
    'sg ri nth must 1 eq (
      ri W divmod draw-cell
    ) () if
    1 plus
  ) while drop
  sdv 1 eq smxv 0 ge and (
    smxv smyv 2 draw-cell-color
  ) () if
) show
