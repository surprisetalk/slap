-- Runtime panic tests
-- Each test is a single line that should crash with a specific error.
-- Run via: make test-panic (see Makefile)
-- This file is NOT run directly; the test harness runs each line separately.

-- FORMAT: -- EXPECT: <error substring>
-- <code that should panic>

-- EXPECT: type error
drop

-- EXPECT: type error
swap

-- EXPECT: type error
plus

-- EXPECT: division by zero
1 0 div

-- EXPECT: division by zero
1 0 mod

-- EXPECT: divmod: division by zero
1 0 divmod

-- EXPECT: wrap: modulus must be non-zero
1 0 wrap

-- EXPECT: assertion failed
0 assert

-- EXPECT: assertion failed
false assert

-- EXPECT: expected tuple
1 apply

-- EXPECT: expected tuple
1 2 3 if

-- EXPECT: type variable
1 2.0 plus

-- EXPECT: index 5 out of bounds
[1 2 3] 5 get must

-- EXPECT: index -1 out of bounds
[1 2 3] -1 get must

-- EXPECT: expected compound
1 len

-- EXPECT: expected seq
1 2 push

-- EXPECT: expected box
1 free

-- EXPECT: pop: empty list
[] pop must

-- EXPECT: index 0 out of bounds
[] (plus) reduce must

-- EXPECT: unknown word
nonexistent_word_xyz

-- EXPECT: index 5 out of bounds
[1 2 3] 5 99 set must

-- EXPECT: expected box
1 mutate

-- EXPECT: expected box
1 lend

-- EXPECT: expected box
1 clone

-- EXPECT: expected seq
stack pop

-- EXPECT: expected list or tagged
42 (1 plus) each

-- EXPECT: expected list
42 (1 eq) filter

-- EXPECT: check: expected preceding type word
(check)

-- EXPECT: expected ord
[[1 2] [3 4]] sort

-- EXPECT: condition must be int
'x (1 plus) (2 plus) if

-- EXPECT: expected rec
[1 2 3] 'x at

-- EXPECT: MUST FAILED
"_nonexistent_file_abc123.txt" read must

-- EXPECT: write: byte element
"foo.txt" ['x] write

-- EXPECT: write: byte 0 out of range
"foo.txt" [256] write

-- EXPECT: write: byte 0 out of range
"foo.txt" [-1] write

-- EXPECT: MUST FAILED
"_nonexistent_dir_abc123" ls must

-- EXPECT: MUST FAILED
[1114112] utf8-encode must

-- EXPECT: MUST FAILED
[-1] utf8-encode must

-- EXPECT: MUST FAILED
[255] utf8-decode must

-- EXPECT: MUST FAILED
[195] utf8-decode must

-- EXPECT: MUST FAILED
[195 65] utf8-decode must

-- EXPECT: expected tagged value
123 {'foo ()} untag

-- EXPECT: expected list or tagged
123 (1 plus) then

-- EXPECT: expected tagged
123 -1 default

-- EXPECT: tagged values have no length
1 'ok tag len

-- EXPECT: concat: result too large
0 10000 range 0 10000 range cat

-- EXPECT: swap: value too large
0 10000 range 0 10000 range swap

-- EXPECT: stack underflow
1 over

-- EXPECT: stack underflow
over

-- EXPECT: stack underflow
1 2 rot

-- EXPECT: stack underflow
rot

-- EXPECT: stack underflow
1 nip

-- EXPECT: stack underflow
nip

-- EXPECT: stack underflow
1 tuck

-- EXPECT: stack underflow
tuck

-- EXPECT: edit: expected record
1 'x (1 plus) edit

-- EXPECT: key
{'a 1} 'b (1 plus) edit must

-- EXPECT: recursion depth exceeded
'inf recur (inf) def inf

-- EXPECT: MUST FAILED
"garbage" parse-http must

-- ===== Error message detail: "got X" wording =====
-- These verify that type errors (whether caught at type-check or at runtime)
-- name the actual type that tripped the check, not just that a check tripped.
-- The substring "got X" must appear consistently across both paths.

-- EXPECT: got int
1 2.0 plus

-- EXPECT: got sym
'x 1 sub

-- EXPECT: got list
[1 2] 3 mul

-- EXPECT: got sym
'x (1) (2) if

-- EXPECT: got list
[1 2 3] 'x at

-- EXPECT: got int
42 1 'x into

-- EXPECT: got list
[1 2 3] 'x (1 plus) edit

-- EXPECT: got int
42 free

-- EXPECT: got int
42 () lend

-- EXPECT: got int
42 () mutate

-- EXPECT: got int
42 clone

-- EXPECT: got int
42 () then

-- EXPECT: got int
42 0 default

-- EXPECT: got int
42 sort

-- EXPECT: got int
42 dedup

-- EXPECT: got int
42 loop

-- EXPECT: got int
1 42 while

-- EXPECT: lt: type mismatch, got int and float
1 2.0 lt

-- Source-location tests: every case below asserts the reported line+col.
-- Each test runs in a file whose first (and only) non-empty line is line 1.

-- EXPECT: division by zero
-- EXPECT-LINE: 1
-- EXPECT-COL: 5
1 0 div

-- EXPECT: mod: division by zero
-- EXPECT-LINE: 1
-- EXPECT-COL: 5
1 0 mod

-- EXPECT: index 0 out of bounds
[] 0 get must

-- EXPECT: index 5 out of bounds
[10 20 30] 5 get must

-- ===== Uncovered die() sites =====

-- EXPECT: out of bounds
[] first

-- EXPECT: out of bounds
[] last

-- EXPECT: dip: need body and value
1 dip

-- EXPECT: loop: expected tuple
42 loop

-- EXPECT: cond: expected tuple or record
1 1 1 cond

-- EXPECT: untag: expected tuple or record
1 'ok tag 1 untag

-- EXPECT: untag: need even number of clauses
1 'ok tag {'ok} untag

-- EXPECT: key
{'a 1} 'b at must

-- EXPECT: out of bounds
[] max-of

-- EXPECT: out of bounds
[] min-of

-- ===== Parser panics (via must on no result) =====

-- EXPECT: MUST FAILED
"" ok parse-int must

-- EXPECT: MUST FAILED
"abc" ok parse-int must

-- EXPECT: MUST FAILED
"-" ok parse-int must

-- EXPECT: MUST FAILED
"a" ok "abc" parse-exact must

-- EXPECT: MUST FAILED
"xyz" ok "abc" parse-exact must

-- EXPECT: MUST FAILED
"hello" ok "=" parse-until must

-- EXPECT: MUST FAILED
"" ok parse-float must

