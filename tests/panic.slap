-- Runtime panic tests
-- Each test is a single line that should crash with a specific error.
-- Run via: make test-panic (see Makefile)
-- This file is NOT run directly; the test harness runs each line separately.

-- FORMAT: -- EXPECT: <error substring>
-- <code that should panic>

-- EXPECT: type error
drop

-- EXPECT: type error
swap

-- EXPECT: type error
plus

-- EXPECT: division by zero
1 0 div

-- EXPECT: division by zero
1 0 mod

-- EXPECT: assertion failed
0 assert

-- EXPECT: assertion failed
false assert

-- EXPECT: expected tuple
1 apply

-- EXPECT: expected tuple
1 2 3 if

-- EXPECT: type variable
1 2.0 plus

-- EXPECT: index 5 out of bounds
[1 2 3] 5 get

-- EXPECT: index -1 out of bounds
[1 2 3] -1 get

-- EXPECT: expected list
1 len

-- EXPECT: expected list
1 2 give

-- EXPECT: expected box
1 free

-- EXPECT: grab: empty list
[] grab

-- EXPECT: index 0 out of bounds
[] (plus) reduce

-- EXPECT: unknown word
nonexistent_word_xyz

-- EXPECT: out of bounds
[1 2 3] 5 99 set

-- EXPECT: expected box
1 mutate

-- EXPECT: expected box
1 lend

-- EXPECT: expected box
1 clone

-- EXPECT: empty tuple
stack pop

-- EXPECT: expected list
42 (1 plus) map

-- EXPECT: expected list
42 (1 eq) filter

-- EXPECT: scrutinee must be a symbol
1 2 3 match

-- EXPECT: check: expected preceding type word
(check)

-- EXPECT: sort: only single-slot
[[1 2] [3 4]] sort

-- EXPECT: condition must be int
'x (1 plus) (2 plus) if

-- EXPECT: expected rec
[1 2 3] 'x at

-- EXPECT: read: cannot open
"_nonexistent_file_abc123.txt" read

-- EXPECT: write: byte element
"foo.txt" ['x] write

-- EXPECT: write: byte 0 out of range
"foo.txt" [256] write

-- EXPECT: write: byte 0 out of range
"foo.txt" [-1] write

-- EXPECT: ls: cannot open directory
"_nonexistent_dir_abc123" ls

-- EXPECT: utf8-encode: codepoint
[1114112] utf8-encode

-- EXPECT: utf8-encode: codepoint
[-1] utf8-encode

-- EXPECT: utf8-decode: invalid lead byte
[255] utf8-decode

-- EXPECT: utf8-decode: truncated sequence
[195] utf8-decode

-- EXPECT: utf8-decode: invalid continuation byte
[195 65] utf8-decode

-- EXPECT: expected tagged value
123 {'foo ()} -1 untag

-- EXPECT: expected tagged value
123 (1 plus) then

-- EXPECT: expected tagged
123 -1 default

-- EXPECT: expected tuple, got tagged
1 'ok tag size

-- EXPECT: concat: result too large
0 10000 range 0 10000 range cat

-- EXPECT: swap: value too large
0 10000 range 0 10000 range swap
