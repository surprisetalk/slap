-- Type system tests
-- Run with: ./slap --check tests/type.slap
-- All code here should type-check cleanly

-- ===== Typed primitive declarations =====

-- Declare types for user-defined functions using effect

'double [int lent in  int move out] effect

-- The body must be provided before the type annotation
'double (2 mul) [int lent in  int move out] effect def

-- ===== Basic arithmetic types =====
2 3 plus drop
2.0 3.0 plus drop
5 neg drop

-- ===== Comparison types =====
3 5 eq drop
3 5 lt drop

-- ===== Logic types =====
1 not drop
1 0 and drop
0 1 or drop

-- ===== Conversions =====
42 itof drop
3.14 ftoi drop

-- ===== Float math =====
2.0 fsqrt drop
1.0 fsin drop
1.0 fcos drop
3.7 ffloor drop
3.2 fceil drop
2.5 fround drop
1.0 fexp drop
1.0 flog drop
2.0 3.0 fpow drop

-- ===== List operations =====
list drop
[1 2 3] len drop

-- ===== Box lifecycle =====
42 box free

-- ===== Integer modulo =====
10 3 mod drop

-- ===== String (list of int) =====
"hello" len drop

-- ===== Assertions =====
1 assert
true assert

-- ===== Multiple operations in sequence =====
2 3 plus 4 mul 1 sub drop

-- ===== Nested arithmetic =====
1 2 plus 3 4 plus mul drop

-- ===== User-defined typed functions =====

-- Define a typed increment function
'my-inc (1 plus) [int lent in  int move out] effect def

5 my-inc 6 eq assert

-- Define typed double (polymorphic over num)
'my-double (2 mul) ['a num lent in  'a num move out] effect def

3 my-double 6 eq assert

-- Type declaration for existing primitive
'not [int lent in  int move out] effect

-- Type declarations for existing primitives (should not re-bind)
'eq ['a lent in  'a lent in  int move out] effect

-- ===== End-to-end: typed program =====
'bump (1 plus) [int lent in  int move out] effect def

0 bump bump bump 3 eq assert

-- ===== Tagged unions =====
123 ok print
123 ok (1 plus) then -1 default print
42 ok -1 default print
"fail" no -1 default print

-- exhaustive untag with union
42 ok {'ok 'int 'no 'str} union {'ok (1 plus) 'no (drop 0)} -1 untag print

-- union through then
42 ok {'ok 'int 'no 'str} union (1 plus) then {'ok () 'no (drop 0)} -1 untag print

-- ===== Protocol constraints =====

-- seq: list-only operations with typed elements
'my-push ['a seq own in  'a own in  'a seq move out] effect
'my-len ['a sized lent in  int move out] effect
'my-max ['a ord lent in  'a ord lent in  'a ord move out] effect

-- sized: works on lists, tuples, and records
[1 2 3] len drop
(1 2 3) len drop
{'x 10} len drop

-- seq: list operations
[1 2 3] 0 get drop
[1 2 3] 1 42 set drop
[1 2] [3 4] cat drop
[1 2 3] 99 push drop
[1 2 3] pop drop drop

-- ord: sort requires orderable elements
[3 1 2] sort drop
['c 'a 'b] sort ['a 'b 'c] eq assert

-- protocol constraint in user-defined function
'list-len (len) ['a seq lent in  int move out] effect def
[1 2 3] list-len 3 eq assert

-- ord constraint in user-defined function
'my-sort (sort) ['a ord seq own in  'a ord seq move out] effect def
[3 1 2] my-sort [1 2 3] eq assert

"Type check tests passed!" print
