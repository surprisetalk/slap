-- Type error tests
-- Each case should produce exactly one type error when run with --check
-- Run via: python3 tests/run_type_errors.py

-- EXPECT: type error
-- TYPE ERROR: dup on box (not copyable)
42 box dup

-- EXPECT: type error
-- TYPE ERROR: plus on mismatched types (int + float)
1 2.0 plus

-- EXPECT: type error
-- TYPE ERROR: mod on float (int-only)
2.0 3.0 mod

-- EXPECT: type error
-- TYPE ERROR: not on float (int-only)
2.0 not

-- EXPECT: type error
-- TYPE ERROR: assert on float (int-only)
1.0 assert

-- EXPECT: type error
-- TYPE ERROR: fsqrt on int (float-only)
42 fsqrt

-- EXPECT: type error
-- TYPE ERROR: ftoi on int (float-only)
42 ftoi

-- EXPECT: type error
-- TYPE ERROR: itof on float (int-only)
3.14 itof

-- EXPECT: type error
-- TYPE ERROR: free on int (box-only)
42 free

-- EXPECT: type error
-- TYPE ERROR: plus needs 2 args, stack has 1
42 plus

-- EXPECT: copyable
-- TYPE ERROR: can't drop a box (not copyable, must free)
42 box drop

-- EXPECT: type variable
-- TYPE ERROR: int + float (type var 'a must be same for both args)
1 2.0 mul

-- EXPECT: type variable
-- TYPE ERROR: sub with mismatched types
3 1.0 sub

-- EXPECT: type error
-- TYPE ERROR: push to non-list
42 99 push

-- EXPECT: type error
-- TYPE ERROR: range with float args
1.0 5.0 range

-- EXPECT: type error
-- TYPE ERROR: sort of non-list
42 sort

-- EXPECT: type error
-- TYPE ERROR: get on int (not a list)
42 0 get

-- EXPECT: copyable
-- TYPE ERROR: dup a box (linear)
42 box dup free free

-- EXPECT: function body consumes
-- TYPE ERROR: body consumes wrong number of inputs
(drop drop) [int lent in  int move out] effect 'bad def

-- EXPECT: function body produces
-- TYPE ERROR: body produces wrong number of outputs
(dup) [int lent in  int move out] effect 'bad2 def

-- EXPECT: type error
-- TYPE ERROR: plus on int result (eq returns int, plus expects num)
1 2 eq 3.0 plus

-- EXPECT: type error
-- TYPE ERROR: plus on box
42 box 1 plus

-- EXPECT: type error
-- TYPE ERROR: and on float (int-only)
1.0 2.0 and

-- EXPECT: type error
-- TYPE ERROR: or on float (int-only)
1.0 2.0 or

-- EXPECT: type error
-- TYPE ERROR: swap with only 1 value (box)
42 box swap

-- EXPECT: function body consumes
-- TYPE ERROR: body declares 2 inputs but only consumes 1
(drop) [int lent in  int lent in  int move out] effect 'foo def

-- EXPECT: already defined
-- TYPE ERROR: duplicate def
(1) 'aaa def
(2) 'aaa def

-- EXPECT: already defined
-- TYPE ERROR: def shadows outer def
1 'bbb def
(2 'bbb def) 'ccc def

-- EXPECT: shadows existing definition
-- TYPE ERROR: let shadows def
(1) 'ddd def
1 'ddd let

-- EXPECT: already bound
-- TYPE ERROR: let shadows let
1 'eee let
2 'eee let

-- EXPECT: shadows existing definition
-- TYPE ERROR: let inside closure shadows outer def (issue #7)
(1) 'fff def
(2 'fff let fff) 'ggg def

-- EXPECT: already bound
-- TYPE ERROR: let inside closure shadows outer let
3 'hhh let
(4 'hhh let hhh) 'iii def

-- EXPECT: shadows existing definition
-- TYPE ERROR: let shadows def in wide-effect closure (>8 args)
(1) 'jjj def
('a1 let 'a2 let 'a3 let 'a4 let 'a5 let 'a6 let 'a7 let 'a8 let 'a9 let 'jjj let jjj) 'kkk def

-- EXPECT: expected num
-- TYPE ERROR: plus on list inside non-simple tuple (soundness: nested structure)
(1 [2 3] plus) 'bad3 def

-- EXPECT: expected num
-- TYPE ERROR: plus on tuple inside non-simple tuple
(1 (2 3) plus) 'bad4 def

-- EXPECT: expected int
-- TYPE ERROR: and on float inside non-simple tuple with nested list
(1.0 [1 2] drop and) 'bad5 def

-- EXPECT: expected num
-- TYPE ERROR: plus on list inside recursive non-simple tuple
(dup 0 eq (drop 1) (1 sub [2 3] plus) if) 'bad6 def

-- EXPECT: type error
-- TYPE ERROR: read expects list, not int
42 read

-- EXPECT: type error
-- TYPE ERROR: write expects list for path, not int
42 [1 2 3] write

-- EXPECT: type error
-- TYPE ERROR: ls expects list, not int
42 ls


-- EXPECT: type error
-- TYPE ERROR: tag needs value and symbol, not just symbol
'foo tag

-- EXPECT: expected tagged
-- TYPE ERROR: default on plain int
42 -1 default

-- EXPECT: expected tagged
-- TYPE ERROR: default on list
[1 2 3] -1 default

-- EXPECT: produce different types
-- TYPE ERROR: case clause bodies disagree (int vs list)
42 ok () {'ok (1 plus) 'no (list)} case


-- EXPECT: expected seq, got tagged
-- TYPE ERROR: push onto tagged
1 'x tag 99 push

-- EXPECT: expected seq, got tagged
-- TYPE ERROR: pop from tagged
1 'x tag pop

-- EXPECT: expected seq, got tagged
-- TYPE ERROR: get on tagged
1 'x tag 0 get

-- EXPECT: expected semigroup, got tagged
-- TYPE ERROR: cat on tagged
[1] 1 'x tag cat

-- EXPECT: expected num, got tagged
-- TYPE ERROR: arithmetic on tagged
42 ok 1 plus

-- EXPECT: expected num, got tagged
-- TYPE ERROR: tagged value in mul
42 ok 2 mul

-- EXPECT: expected list
-- TYPE ERROR: rise of non-list
42 rise

-- EXPECT: expected list
-- TYPE ERROR: fall of non-list
42 fall

-- EXPECT: expected list
-- TYPE ERROR: shape of non-list
42 shape

-- EXPECT: expected list
-- TYPE ERROR: reverse of non-list
42 reverse

-- EXPECT: expected list
-- TYPE ERROR: dedup of non-list
42 dedup

-- EXPECT: expected seq, got tagged
-- TYPE ERROR: pop from tagged value
1 'x tag pop

-- ===== Protocol constraint errors =====

-- EXPECT: expected seq, got tuple
-- TYPE ERROR: push onto tuple (seq is list-only)
(1 2 3) 4 push

-- EXPECT: expected seq, got tuple
-- TYPE ERROR: pop from tuple
(1 2 3) pop

-- EXPECT: expected seq, got int
-- TYPE ERROR: push onto non-seq
42 99 push

-- EXPECT: expected seq, got tuple
-- TYPE ERROR: get on tuple (seq is list-only)
(1 2 3) 0 get

-- EXPECT: expected seq, got tuple
-- TYPE ERROR: set on tuple
(1 2 3) 0 99 set

-- EXPECT: expected ord
-- TYPE ERROR: sort list of lists (lists aren't Ord)
[[1] [2]] sort

-- EXPECT: type variable 'a' mismatch
-- TYPE ERROR: heterogeneous dict values (no need for free now that dicts are stackable)
dict "k" 1 insert "j" "two" insert

-- EXPECT: expected dict
-- TYPE ERROR: insert expects dict
42 "k" 1 insert

-- EXPECT: type variable 'a' mismatch
-- TYPE ERROR: heterogeneous dict values
dict "a" 1 insert "b" "two" insert free

-- EXPECT: body must be 1->1
-- TYPE ERROR: each body on dict must be 1->1 (receives (k v) tuple)
dict (drop) each free


-- EXPECT: discard linear payload
-- TYPE ERROR: case on tagged box (branches can leak)
42 box ok () {'ok (drop)} case

-- EXPECT: linear payload
-- TYPE ERROR: tagging a box without consuming the tagged
42 box ok

-- EXPECT: stack effects
-- TYPE ERROR: if branches produce different arity
1 1 lt (99 99) (0) if drop drop

-- EXPECT: never referenced
-- TYPE ERROR: linear value let-bound inside quotation, never used → captured and leaked
(42 box 'b let) 'leak def leak

-- EXPECT: aliases the box
-- TYPE ERROR: let-bind compound inside lend body (aliases box backing)
[1 2 3] box ('snap let snap) lend swap free drop

-- EXPECT: requires copyable
-- TYPE ERROR: closure capturing linear binding cannot be duplicated
42 box 'b let (b free) dup apply apply

-- EXPECT: linear values produced by 'box'
-- TYPE ERROR: list literal cannot contain box
[42 box]

-- EXPECT: linear values produced by 'box'
-- TYPE ERROR: record literal cannot contain box
{'k box}

-- EXPECT: already been consumed
-- TYPE ERROR: linear-capturing closure applied twice via let binding
42 box 'b let (b free) 'f let f apply f apply

-- EXPECT: already been consumed
-- TYPE ERROR: linear-capturing closure double-applied through apply
42 box 'b let (b free) 'f let f apply f apply

-- EXPECT: needs 3 input
-- TYPE ERROR: case without default arg (would stack-underflow at runtime)
123 'foo tag {'foo (1 plus)} case

-- EXPECT: already been consumed
-- TYPE ERROR: linear-capturing closure returned from def, applied twice
(42 box 'b let (b free)) 'make-freer def
make-freer 'f let
f apply
f apply

-- EXPECT: already been consumed
-- TYPE ERROR: linear-capturing closure via def chain, applied twice
(42 box 'b let (b free)) 'inner-maker def
(inner-maker) 'outer-maker def
outer-maker 'f let
f apply
f apply

-- EXPECT: already been consumed
-- TYPE ERROR: linear-capturing closure from apply, applied twice
(42 box 'b let (b free)) apply 'f let
f apply
f apply

-- EXPECT: clause body may not produce a linear value
-- TYPE ERROR: case clause producing a linear closure
(1 0 {(1 eq) (42 box 'b let (b free))} case) 'bad-case def

-- EXPECT: already been consumed
-- TYPE ERROR: if-branch returning linear closure, applied twice
(1 (42 box 'b let (b free)) (99 box 'c let (c free)) if) 'maker def
maker 'f let
f apply
f apply

-- EXPECT: body may not produce a linear-capturing closure
-- TYPE ERROR: each body producing linear closure (would alias into list)
[1] (drop 42 box 'b let (b free)) each

-- EXPECT: cannot embed a linear value into a stackable container
-- TYPE ERROR: push a box into a list (would be cloned by deep_copy_values on dup)
list 42 box push drop

-- EXPECT: cannot embed a linear value into a stackable container
-- TYPE ERROR: into record would smuggle box past linearity
rec 42 box 'b into drop

-- EXPECT: cannot embed a linear value into a stackable container
-- TYPE ERROR: set would place box into list slot
[1 2 3] 0 42 box set drop

-- EXPECT: nested tuple literal
-- TYPE ERROR: lend body captures snapshot into a nested tuple (would alias past mutate)
{'x 1} box (dup (swap) dip) lend free

-- EXPECT: missing clause
-- TYPE ERROR: case on a typed union missing a variant
1 ok {'ok 'int 'no 'int} union 0 {'ok (1 plus)} case drop

-- EXPECT: missing clause
-- TYPE ERROR: case on a 3-variant union missing two
1 'alpha tag {'alpha 'int 'beta 'int 'gamma 'int} union 0 {'alpha (1 plus)} case drop

-- EXPECT: branches produce different types
-- TYPE ERROR: if inside a recursive body with type-mismatched branches
'bad (dup 0 eq ("hi") (99) if) def
5 bad drop

-- EXPECT: inconsistent stack effects
-- TYPE ERROR: A5 — case predicate-mode with mixed empty/non-empty bodies
"y" -99 {("x" eq) (42) ("y" eq) ()} case 1 plus print

-- EXPECT: unknown type
-- TYPE ERROR: A6 — either schema with typo'd variant type
'badsig [list own in  {'ok 'typoedtype 'no ()} either move out] effect (pop) def
