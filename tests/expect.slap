-- ===== Comparison =====
3 3 eq assert
3 5 lt assert
5 3 lt not assert

-- ===== Symbols =====
'hello 'hello eq assert
'hello 'world eq not assert

-- ===== Definitions (def auto-executes tuples) =====
'double (2 mul) def
5 double 10 eq assert

-- ===== Let (pushes value, no auto-exec) =====
42 'answer let
answer 42 eq assert

-- ===== Recursion =====
'factorial recur (
  dup 1 le (drop 1) (dup 1 sub factorial mul) if
) def
5 factorial 120 eq assert
1 factorial 1 eq assert
0 factorial 1 eq assert

