-- ===== Adversarial: divmod / wrap / shape / float math =====

-- divmod: quotient on top, remainder below
17 5 divmod 3 eq assert 2 eq assert
-- divmod with negative dividend: C truncation (toward zero)
-17 5 divmod -3 eq assert -2 eq assert
-- divmod identity: a = q*b + r
37 7 divmod 'q let 'r let q 7 mul r plus 37 eq assert

-- wrap: negative-safe modulus
7 5 wrap 2 eq assert
-3 5 wrap 2 eq assert
0 5 wrap 0 eq assert
-- wrap matches mod for non-negative inputs
100 7 wrap 100 7 mod eq assert

-- shape on nested list
[[1 2] [3 4]] shape [2 2] eq assert
[[1 2 3]] shape [1 3] eq assert
-- shape on empty list: one dimension of zero
[] shape [0] eq assert
-- shape on flat list still returns one dim
[10 20 30 40] shape [4] eq assert

-- ftan 0 = 0
0.0 ftan 0.0 eq assert

-- fatan2: atan2(0, 1) = 0
0.0 1.0 fatan2 0.0 eq assert
-- fatan2: atan2(1, 0) = pi/2 (within float tolerance)
1.0 0.0 fatan2 pi 2.0 div sub fabs 0.000001 lt assert

-- millis: non-negative and monotonic across two reads
millis 0 lt not assert
millis millis swap sub 0 lt not assert

