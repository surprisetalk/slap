[240 159 152 128] utf8-decode [128512] eq assert

-- mixed ASCII and multibyte: "Ré" = [82 233]
[82 233] utf8-encode [82 195 169] eq assert
[82 195 169] utf8-decode [82 233] eq assert

-- full round-trip with file I/O
"_test_fs.bin" [82 233] utf8-encode write
"_test_fs.bin" read utf8-decode [82 233] eq assert

-- cleanup test file
"_test_fs.bin" [] write

