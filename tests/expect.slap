-- ===== Complex: box with record inside =====
{'count 0 'total 0} box
  (dup 'count at 1 plus 'count into) mutate
  (dup 'count at 1 plus 'count into) mutate
  (dup 'total at 100 plus 'total into) mutate
  () lend
  dup 'count at 2 eq assert
  'total at 100 eq assert
free

