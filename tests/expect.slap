dict
"a" 1 insert "b" 2 insert "c" 3 insert "d" 4 insert
"e" 5 insert "f" 6 insert "g" 7 insert "h" 8 insert
"i" 9 insert "j" 10 insert "k" 11 insert "l" 12 insert
dict-len 12 eq assert
"h" of 0 default 8 eq assert
"z" of 999 default 999 eq assert
dict-free

