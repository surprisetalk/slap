'make-adder2 (
  'a let
  ('b let a b plus)
) def
3 make-adder2 'add3 let
4 add3 apply 7 eq assert
10 add3 apply 13 eq assert

-- ===== Complex: closure over captured variable in map =====
'scale (
  'factor let
  (factor mul)
) def
3 scale 'triple let
[1 2 3 4] (triple apply) map [3 6 9 12] eq assert

-- ===== Complex: GCD via recursion =====
'gcd recur (
  dup 0 eq (drop) (swap over mod gcd) if
) def
12 8 gcd 4 eq assert
100 75 gcd 25 eq assert
17 13 gcd 1 eq assert
0 5 gcd 5 eq assert

-- ===== Complex: iterative power =====
'pow (
  1 rot rot
  (dup 0 eq not) (
    1 sub (swap over mul swap) dip
  ) while
  drop drop
) def
2 10 pow 1024 eq assert
3 4 pow 81 eq assert
5 0 pow 1 eq assert
7 1 pow 7 eq assert

-- ===== Complex: records built incrementally =====
rec 10 'x into 20 'y into 30 'z into
  dup 'x at 10 eq assert
  dup 'y at 20 eq assert
  'z at 30 eq assert

-- ===== Complex: record overwrite =====
{'x 1 'y 2} 99 'x into 'x at 99 eq assert

-- ===== Complex: box mutate in while loop =====
0 box
  5 (dup 0 eq not) (1 sub swap (1 plus) mutate swap) while
  drop
  () lend 5 eq assert
free

-- ===== Complex: clone and diverge boxes =====
10 box clone
  (100 plus) mutate
  swap
  () lend 10 eq assert
  swap
  () lend 110 eq assert
free free

