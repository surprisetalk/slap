dict-keys len 3 eq assert
dict-values sum 6 eq assert dict-free

-- dict-clone independence
dict "a" 1 insert dict-clone "b" 2 insert
dict-len 2 eq assert
swap dict-len 1 eq assert
dict-free dict-free

