[1] [2 3] [4 5 6] rot [1] eq assert [4 5 6] eq assert [2 3] eq assert

-- nip with tagged values
42 ok 99 ok nip -1 default 99 eq assert

-- tuck with records
rec 1 'a into  rec 2 'b into  tuck 'b at 2 eq assert 'a at 1 eq assert 'b at 2 eq assert

