[5 3 8 1 7] dup (4 lt) where select [3 1] eq assert

-- ===== Typed user function with body check =====
'square (dup mul) [int lent in  int move out] effect def
7 square 49 eq assert

-- ===== Closures =====
'make-adder (
  'n let
  (n plus)
) def
5 make-adder 3 swap apply 8 eq assert
10 make-adder 7 swap apply 17 eq assert

'make-multiplier (
  'factor let
  (factor mul)
) def
3 make-multiplier 7 swap apply 21 eq assert

-- ===== Adversarial: recursive list building =====
'iota recur (
  dup 0 le (drop list) (dup 1 sub iota swap give) if
) def
5 iota [1 2 3 4 5] eq assert
0 iota [] eq assert

-- ===== Adversarial: mutual-style via def =====
'even? recur (dup 0 eq (drop 1) (1 sub odd?) if) def
'odd? (dup 0 eq (drop 0) (1 sub even?) if) def
4 even? assert
3 odd? assert
0 even? assert

-- ===== Adversarial: higher-order composition =====
[1 2 3 4 5]
  (sqr) map
  (10 lt) filter
  (plus) reduce
14 eq assert

-- ===== Adversarial: table + fold =====
[1 2 3 4] (sqr) table
  (1 get) map
  (plus) reduce
30 eq assert

-- ===== Adversarial: box with list mutation =====
[1 2 3] box
  ((10 plus) map) mutate
  () lend
  [11 12 13] eq assert
free

-- ===== Adversarial: deeply nested lists =====
[[1] [2] [3]] flatten [1 2 3] eq assert
[[[1 2] [3 4]] [[5 6]]] flatten [[1 2] [3 4] [5 6]] eq assert

