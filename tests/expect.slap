-- ===== TCP Loopback =====
'tcp-roundtrip (
  19201 tcp-listen must 's1 let
  "127.0.0.1" 19201 tcp-connect must 'c1 let
  s1 tcp-accept must 'p1 let 's1a let

  c1 "hello" tcp-send must drop 'c1a let
  p1 1024 tcp-recv must 'd1 let 'p1a let
  d1 "hello" eq assert

  p1a "world" tcp-send must drop 'p1b let
  c1a 1024 tcp-recv must 'd2 let 'c1b let
  d2 "world" eq assert

  c1b tcp-close
  p1b tcp-close
  s1a tcp-close
) def tcp-roundtrip

'tcp-multi-send (
  19202 tcp-listen must 's2 let
  "127.0.0.1" 19202 tcp-connect must 'c2 let
  s2 tcp-accept must 'p2 let 's2a let

  c2 "aaa" tcp-send must drop 'c2a let
  c2a "bbb" tcp-send must drop 'c2b let
  c2b "ccc" tcp-send must drop 'c2c let

  p2 1024 tcp-recv must 'chunk1 let 'p2a let
  chunk1 len 0 gt assert

  c2c tcp-close
  p2a tcp-close
  s2a tcp-close
) def tcp-multi-send

'tcp-empty-send (
  19203 tcp-listen must 's3 let
  "127.0.0.1" 19203 tcp-connect must 'c3 let
  s3 tcp-accept must 'p3 let 's3a let

  c3 list tcp-send must drop 'c3a let

  c3a tcp-close
  p3 tcp-close
  s3a tcp-close
) def tcp-empty-send

'tcp-large-data (
  19204 tcp-listen must 's4 let
  "127.0.0.1" 19204 tcp-connect must 'c4 let
  s4 tcp-accept must 'p4 let 's4a let

  0 1000 range 'big let
  c4 big (256 mod) each tcp-send must drop 'c4a let
  c4a tcp-close

  p4 list
  (swap 4096 tcp-recv must 'ch let swap ch cat ch len 0 gt) () while
  len 1000 eq assert

  tcp-close
  s4a tcp-close
) def tcp-large-data

-- ===== HTTP Prelude =====
'test-parse-http (
  "HTTP/1.1 200 OK" crlf cat "Content-Type: text/html" cat crlf cat crlf cat "hello body" cat
  parse-http must 'body let 'headers let 'status let
  status 200 eq assert
  headers len 1 eq assert
  headers 0 get must 'key at must "Content-Type" eq assert
  headers 0 get must 'value at must "text/html" eq assert
  body "hello body" eq assert
) def test-parse-http

'test-http-request (
  "GET" "example.com" "/path" list list http-request 'req let
  req 4 take-n "GET " eq assert
) def test-http-request

-- ===== HTTP Integration (Loopback) =====
'test-http-loopback (
  19205 tcp-listen must 'srv let
  "127.0.0.1" 19205 tcp-connect must 'cli let
  srv tcp-accept must 'peer let 'srv2 let

  "HTTP/1.1 200 OK" crlf cat
  "Content-Type: text/plain" cat crlf cat
  "Content-Length: 5" cat crlf cat
  crlf cat "hello" cat
  'http-resp let
  peer http-resp tcp-send must drop 'peer2 let
  peer2 tcp-close

  cli list
  (swap 4096 tcp-recv must 'ch let swap ch cat ch len 0 gt) () while
  swap 'cli2 let
  cli2 tcp-close
  srv2 tcp-close

  parse-http must 'rbody let 'rhdrs let 'rstat let
  rstat 200 eq assert
  rbody "hello" eq assert
  rhdrs len 2 eq assert
) def test-http-loopback

-- ===== Tagged Unions (Sum Types) =====

-- basic tag and untag
123 'foo tag {'foo ()} untag 123 eq assert

-- record clauses
123 'foo tag {'foo (1 plus) 'bar (2 plus)} untag 124 eq assert
456 'bar tag {'foo (1 plus) 'bar (2 plus)} untag 458 eq assert

-- multi-slot payload (tuple)
(1 2 3) 'triple tag {'triple ()} untag (1 2 3) eq assert

-- nested tags
42 'inner tag 'outer tag {'outer ()} untag 42 'inner tag eq assert

-- dup/drop/swap on tagged values
123 ok dup eq assert
123 ok 456 ok nip 456 ok eq assert

-- equality
1 ok 1 ok eq assert
1 ok 2 ok eq not assert
1 ok 1 no eq not assert

-- ok/no are sugar for 'ok tag / 'no tag
42 ok 42 'ok tag eq assert
"x" no "x" 'no tag eq assert

-- then (monadic chaining)
123 ok (1 plus ok) then (2 mul ok) then -1 default 248 eq assert
"oops" no (1 plus ok) then -1 default -1 eq assert
"x" no (1 plus ok) then (2 mul ok) then 0 default 0 eq assert

-- then preserves non-ok tag and payload
"fail" no (999 plus ok) then {'no ()} untag "fail" eq assert

-- default
42 ok -1 default 42 eq assert
"fail" no "" default "" eq assert

-- tag with symbol payload
'hello ok (drop "yes" ok) then "no" default "yes" eq assert

-- tag with float payload
2.0 ok (1.0 plus ok) then 0.0 default 3.0 eq assert

-- result type pattern: safe division
'safe-div ('d let 'n let
  d 0 eq ("division by zero" no) (n d div ok) if
) def
10 2 safe-div -1 default 5 eq assert
10 0 safe-div -1 default -1 eq assert
10 2 safe-div (3 mul ok) then -1 default 15 eq assert
10 0 safe-div (3 mul ok) then -1 default -1 eq assert

-- chained safe operations
'safe-sqrt ('n let
  n 0 lt ("negative" no) (n itof fsqrt ftoi ok) if
) def
16 safe-sqrt -1 default 4 eq assert
-1 safe-sqrt -1 default -1 eq assert
16 safe-sqrt (2 mul ok) then -1 default 8 eq assert

-- union (type annotation, runtime no-op with symbol values)
123 ok {'ok 'int 'no 'str} union print

-- exhaustive untag with union passes type checker
42 ok {'ok 'int 'no 'str} union {'ok (1 plus) 'no (drop 0)} untag 43 eq assert

-- union propagates through then
10 ok {'ok 'int 'no 'str} union (5 plus ok) then {'ok () 'no (drop 0)} untag 15 eq assert

-- three-variant union, all handled
42 'a tag {'a 'int 'b 'int 'c 'int} union {'a (1 plus) 'b (2 plus) 'c (3 plus)} untag 43 eq assert

-- untag without union: no exhaustiveness check (open tagged)
42 'foo tag {'foo (1 plus)} untag 43 eq assert

-- default preserves payload type through then chain
42 ok (1 plus ok) then (2 mul ok) then -1 default 86 eq assert

-- then body type is checked with union
42 ok {'ok 'int 'no 'str} union (1 plus ok) then -1 default 43 eq assert

-- no value through then with union: body doesn't run, no type error
"oops" no {'ok 'int 'no 'str} union (1 plus ok) then -1 default -1 eq assert

-- tagged through higher-order ops
[1 2 3] (ok -1 default) each [1 2 3] eq assert
[1 2 3] (ok) each (-1 default) each [1 2 3] eq assert
[1 2 3] 0 ok ('n let -1 default n plus ok) fold -1 default 6 eq assert
[10 20 30] 0 (ok -1 default plus) fold 60 eq assert

-- tagged via custom tag function
'tag-as ('s let s tag) def
42 'custom tag-as {'custom (1 plus)} untag 43 eq assert

-- tagged stored in let bindings
42 ok 'x let
x -1 default 42 eq assert
x (2 mul ok) then -1 default 84 eq assert

-- tagged returned from def
'wrap-ok (ok) def
'unwrap (-1 default) def
42 wrap-ok unwrap 42 eq assert

-- nested tags: unwrap outermost
1 'a tag 'b tag 'c tag
  {'c ()} untag
  1 'a tag 'b tag eq assert

-- nested tags: full 3-level unwrap
1 'a tag 'b tag 'c tag
  {'c ()} untag
  {'b ()} untag
  {'a ()} untag
  1 eq assert

-- nested tags: two levels of wrapping/unwrapping
42 'inner tag 'outer tag
  {'outer ({'inner (10 plus)} untag)} untag
  52 eq assert

-- untag with body that returns tagged (re-wrapping)
42 ok {'ok (2 mul ok)} untag -1 default 84 eq assert

-- then chain: 10 deep
1 ok
  (1 plus ok) then (1 plus ok) then (1 plus ok) then (1 plus ok) then (1 plus ok) then
  (1 plus ok) then (1 plus ok) then (1 plus ok) then (1 plus ok) then (1 plus ok) then
  -1 default 11 eq assert

-- no passes through arbitrary then chains
"err" no
  (1 plus ok) then (2 mul ok) then (3 sub ok) then (4 div ok) then
  {'no ()} untag "err" eq assert

-- default with body (tuple) as fallback
42 no 99 default 99 eq assert
42 ok 99 default 42 eq assert

-- tag with record payload
{'x 10 'y 20} ok must 'x at must 10 eq assert

-- tag with list payload
[1 2 3] ok must [1 2 3] eq assert

-- tag with empty tuple payload
() 'unit tag {'unit (drop 1)} untag 1 eq assert

-- mixed custom tags in untag
42 'a tag {'a (1 plus) 'b (2 plus) 'c (3 plus)} untag 43 eq assert
42 'b tag {'a (1 plus) 'b (2 plus) 'c (3 plus)} untag 44 eq assert
42 'c tag {'a (1 plus) 'b (2 plus) 'c (3 plus)} untag 45 eq assert

-- recursive tagged: build a linked list with tags
'cons ('tl let 'hd let hd tl couple 'cons tag) def

'nil (0 'nil tag) def
nil {'nil (drop 0) 'cons (first)} untag 0 eq assert
1 2 nil cons cons {'nil (drop 0) 'cons (first)} untag 1 eq assert

