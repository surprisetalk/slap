['a 'b 'a 'c 'b 'a] classify [0 1 0 2 1 0] eq assert

-- ===== Complex: deep dip nesting =====
1 2 3 (10 plus) dip (20 plus) dip
3 eq assert 32 eq assert 1 eq assert

-- ===== Complex: keep + bi combinations =====
10 (2 mul) keep 10 eq assert 20 eq assert
6 (1 plus) (1 sub) bi 5 eq assert 7 eq assert

-- ===== Complex: repeat for exponentiation =====
1 10 (2 mul) repeat 1024 eq assert

-- ===== Complex: collatz sequence length (iterative) =====
'collatz-len (
  0 swap
  (dup 1 eq not) (
    dup 2 mod 0 eq (2 div) (3 mul 1 plus) if
    swap 1 plus swap
  ) while
  drop
) def
27 collatz-len 111 eq assert
6 collatz-len 8 eq assert
1 collatz-len 0 eq assert

