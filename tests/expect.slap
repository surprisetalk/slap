-- ===== Adversarial: edge cases =====

-- negative arithmetic
-10 -20 plus -30 eq assert
-5 neg 5 eq assert
0 neg 0 eq assert

-- empty collections
[] len 0 eq assert
list len 0 eq assert
stack size 0 eq assert

-- single element list
[42] first 42 eq assert
[42] last 42 eq assert
[42] len 1 eq assert

-- nested if
5 dup 3 lt (drop 0) (dup 10 lt (drop 1) (drop 2) if) if 1 eq assert

-- deeply nested tuples
((1 2 plus)) apply apply 3 eq assert

-- string as list of chars
"a" 0 get 97 eq assert
"" len 0 eq assert

-- range edge cases
0 0 range len 0 eq assert
5 6 range [5] eq assert

-- map on empty list
[] (1 plus) map [] eq assert

-- filter removes all
[1 2 3] (10 lt not) filter [] eq assert

-- fold on single element
[42] 0 (plus) fold 42 eq assert

-- reduce on single element
[42] (plus) reduce 42 eq assert

-- list of lists
[[1 2] [3 4]] 0 get [1 2] eq assert
[[1 2] [3 4]] 1 get [3 4] eq assert

-- reverse
[1 2 3] reverse [3 2 1] eq assert
[] reverse [] eq assert
[42] reverse [42] eq assert

-- dedup
[1 2 2 3 3 3] dedup [1 2 3] eq assert
[1 1 1] dedup [1] eq assert
[] dedup [] eq assert

-- compose chains
(1 plus) (2 mul) compose (3 plus) compose
0 swap apply 5 eq assert

-- box with list
[1 2 3] box
  (0 get) lend 1 eq assert
  ((2 mul) map) mutate
  () lend [2 4 6] eq assert
free

-- record empty
rec rec eq assert

-- multiple record fields
{'a 1 'b 2 'c 3} 'b at 2 eq assert
{'a 1 'b 2 'c 3} 'c at 3 eq assert

-- record into creates new field
{'a 1} 2 'b into 'b at 2 eq assert

-- match with default
'unknown {'red (0) 'blue (1)} -1 match -1 eq assert

-- cond with default
100 {(50 lt) (1)} -1 cond -1 eq assert

-- while that never executes body
10 (dup 5 lt) (2 mul) while 10 eq assert

-- nested def
'outer (
  'inner (10 plus) def
  5 inner
) def
outer 15 eq assert

-- let binding shadowing
10 'x let
'use-x (x 1 plus) def
20 'x let
use-x 21 eq assert

-- tuple pull/put
(10 20 30) 0 pull 10 eq assert drop
(10 20 30) 2 pull 30 eq assert drop
(10 20 30) 1 99 put (10 99 30) eq assert

-- keep-mask all true
[1 2 3] [1 1 1] keep-mask [1 2 3] eq assert

-- keep-mask all false
[1 2 3] [0 0 0] keep-mask [] eq assert

-- index-of not found
[1 2 3] 99 index-of -1 eq assert

-- sort already sorted
[1 2 3] sort [1 2 3] eq assert

-- float operations
2.0 3.0 fpow 8.0 eq assert
1.0 fexp 2.0 lt not assert
0.0 fsin 0.0 eq assert
0.0 fcos 1.0 eq assert

-- ===== Prelude: keep =====
-- keep: x f → f(x) x  (apply f, then push x back)
5 (sqr) keep 5 eq assert 25 eq assert

-- ===== Prelude: bi =====
-- bi: x f g → f(x) g(x)
3 (2 plus) (3 mul) bi 9 eq assert 5 eq assert

