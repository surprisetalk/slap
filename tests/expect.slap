-- ===== Filesystem: write & read round-trip =====
"_test_fs.bin" [72 101 108 108 111] write must drop
"_test_fs.bin" read must [72 101 108 108 111] eq assert

-- write overwrites previous contents
"_test_fs.bin" [1 2 3] write must drop
"_test_fs.bin" read must [1 2 3] eq assert

-- empty file round-trip
"_test_fs.bin" [] write must drop
"_test_fs.bin" read must [] eq assert

-- binary bytes (0 and 255)
"_test_fs.bin" [0 127 255] write must drop
"_test_fs.bin" read must [0 127 255] eq assert

-- single byte
"_test_fs.bin" [42] write must drop
"_test_fs.bin" read must [42] eq assert

-- ===== Filesystem: ls =====
"." ls must len 0 lt not assert

-- ===== UTF-8 encode/decode =====
-- ASCII round-trip
[72 101 108 108 111] utf8-encode must utf8-decode must [72 101 108 108 111] eq assert

-- ASCII encodes as identity
[65 66 67] utf8-encode must [65 66 67] eq assert

-- empty list round-trip
[] utf8-encode must [] eq assert
[] utf8-decode must [] eq assert

-- 2-byte character: U+00E9 (é) = [0xC3, 0xA9]
[233] utf8-encode must [195 169] eq assert
[195 169] utf8-decode must [233] eq assert

-- 3-byte character: U+4E16 (世) = [0xE4, 0xB8, 0x96]
[19990] utf8-encode must [228 184 150] eq assert
[228 184 150] utf8-decode must [19990] eq assert

-- 4-byte character: U+1F600 (😀) = [0xF0, 0x9F, 0x98, 0x80]
[128512] utf8-encode must [240 159 152 128] eq assert
[240 159 152 128] utf8-decode must [128512] eq assert

-- mixed ASCII and multibyte: "Ré" = [82 233]
[82 233] utf8-encode must [82 195 169] eq assert
[82 195 169] utf8-decode must [82 233] eq assert

-- full round-trip with file I/O
"_test_fs.bin" [82 233] utf8-encode must write must drop
"_test_fs.bin" read must utf8-decode must [82 233] eq assert

-- cleanup test file
"_test_fs.bin" [] write must drop

