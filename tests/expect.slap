1 ok 2 ok over -1 default 1 eq assert drop drop

-- ===== Adversarial: String Helpers =====

-- str-find: empty needle in non-empty haystack
"hello" "" str-find 0 eq assert

-- str-find: not found
"hello" "xyz" str-find -1 eq assert

-- str-find: at beginning
"hello world" "hello" str-find 0 eq assert

-- str-find: at end
"hello world" "world" str-find 6 eq assert

-- str-find: middle
"abcdef" "cd" str-find 2 eq assert

-- str-split: delimiter not found returns single element
"hello" "," str-split len 1 eq assert
"hello" "," str-split first "hello" eq assert

-- str-split: empty string
"" "," str-split len 1 eq assert

-- str-split: multiple splits
"a,b,c,d" "," str-split len 4 eq assert

-- str-split: multi-char delimiter
"a::b::c" "::" str-split len 3 eq assert

-- str-join roundtrip
"a,b,c" "," str-split "," str-join "a,b,c" eq assert

-- int-str basics
42 int-str "42" eq assert
0 int-str "0" eq assert
-7 int-str "-7" eq assert

